{% extends 'back/layout.html.twig' %}

{% block title %}{{ form_title }} — Back Office{% endblock %}
{% block page_title %}{{ form_title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card table-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="fas fa-{% if medicament %}edit{% else %}plus{% endif %} me-2 text-primary"></i>{{ form_title }}</h5>
                <a href="{{ path('back_medicament_index') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                </a>
            </div>
            <div class="card-body p-4">
                <form method="post" action="{{ form_action }}">
                    <input type="hidden" name="_token" value="{{ csrf_token(medicament ? 'medicament_edit_' ~ medicament.id : 'medicament_new') }}">

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                            <input type="text" name="nom" class="form-control" value="{{ medicament ? medicament.nom : '' }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Forme pharmaceutique</label>
                            <input type="text" name="formePharmaceutique" class="form-control" value="{{ medicament ? medicament.formePharmaceutique : '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Dosage standard</label>
                            <input type="text" name="dosageStandard" class="form-control" value="{{ medicament ? medicament.dosageStandard : '' }}">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Contre-indications</label>
                            <textarea name="contreIndications" class="form-control" rows="4">{{ medicament ? medicament.contreIndications : '' }}</textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>{{ submit_label }}
                        </button>
                        <a href="{{ path('back_medicament_index') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
