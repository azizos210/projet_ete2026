{% extends 'back/layout.html.twig' %}

{% block title %}{{ entite }} #{{ entity.id }} — Back Office{% endblock %}
{% block page_title %}{{ entite }} <small class="text-muted fs-6">#{{ entity.id }}</small>{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card table-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>Détails</h5>
                <div class="d-flex gap-2">
                    <a href="{{ path(edit_route, { id: entity.id }) }}" class="btn btn-warning btn-sm">
                        <i class="fas fa-edit me-1"></i>Modifier
                    </a>
                    <button onclick="confirmDelete({{ entity.id }})" class="btn btn-danger btn-sm">
                        <i class="fas fa-trash me-1"></i>Supprimer
                    </button>
                    <a href="{{ path(list_route) }}" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Retour
                    </a>
                </div>
            </div>
            <div class="card-body p-4">
                <table class="table table-bordered table-details mb-0">
                    <tbody>
                        {% for field in fields %}
                        <tr>
                            <th class="bg-light" style="width: 220px;">{{ field.label }}</th>
                            <td>
                                {% if field.type is defined and field.type == 'roles' %}
                                    {% for role in field.value %}
                                        {% if role != 'ROLE_USER' %}
                                            <span class="badge badge-role bg-primary me-1">{{ role|replace({ 'ROLE_': '' }) }}</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">Aucun rôle</span>
                                    {% endfor %}
                                {% elseif field.type is defined and field.type == 'boolean' %}
                                    {% if field.value %}
                                        <span class="badge bg-success">Oui</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Non</span>
                                    {% endif %}
                                {% elseif field.type is defined and field.type == 'datetime' %}
                                    {{ field.value ? field.value|date('d/m/Y H:i') : '--' }}
                                {% elseif field.type is defined and field.type == 'date' %}
                                    {{ field.value ? field.value|date('d/m/Y') : '--' }}
                                {% elseif field.type is defined and field.type == 'count' %}
                                    <span class="badge bg-info">{{ field.value }}</span>
                                {% else %}
                                    {{ field.value ?? '--' }}
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card table-card">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="fas fa-cog me-2 text-secondary"></i>Actions</h5>
            </div>
            <div class="card-body p-4">
                <div class="d-grid gap-3">
                    <a href="{{ path(edit_route, { id: entity.id }) }}" class="btn btn-warning">
                        <i class="fas fa-edit me-2"></i>Modifier
                    </a>
                    <button onclick="confirmDelete({{ entity.id }})" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Supprimer
                    </button>
                    <a href="{{ path(list_route) }}" class="btn btn-outline-primary">
                        <i class="fas fa-list me-2"></i>Voir la liste
                    </a>
                    <a href="{{ path('back_dashboard') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle text-danger me-2"></i>Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Êtes-vous sûr de vouloir supprimer {{ entite|lower }} <strong>#{{ entity.id }}</strong> ?</p>
                <p class="text-danger mt-2 mb-0"><small><i class="fas fa-info-circle me-1"></i>Cette action est irréversible.</small></p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    <input type="hidden" name="_token" value="">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Confirmer la suppression
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% set csrf_name = delete_route|replace({ 'back_': '', '_delete': '' }) ~ '_delete_' ~ entity.id %}
{% set delete_path = path(delete_route, { id: entity.id }) %}

{% block javascripts %}
<script>
function confirmDelete(id) {
    const form = document.getElementById('deleteForm');
    form.action = '{{ delete_path }}';
    form.querySelector('[name="_token"]').value = '{{ csrf_token(csrf_name) }}';
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>
{% endblock %}
