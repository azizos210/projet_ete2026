{% extends 'back/layout.html.twig' %}

{% block title %}{{ form_title }} — Back Office{% endblock %}
{% block page_title %}{{ form_title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card table-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="fas fa-{% if patient %}edit{% else %}plus{% endif %} me-2 text-primary"></i>{{ form_title }}</h5>
                <a href="{{ path('back_patients') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                </a>
            </div>
            <div class="card-body p-4">
                <form method="post" action="{{ form_action }}">
                    <input type="hidden" name="_token" value="{{ csrf_token(patient ? 'patient_edit_' ~ patient.id : 'patient_new') }}">

                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Utilisateur <span class="text-danger">*</span></label>
                            <select name="utilisateur" class="form-select" required>
                                <option value="">-- Sélectionner un utilisateur --</option>
                                {% for u in utilisateurs %}
                                    <option value="{{ u.id }}" {% if selected_utilisateur == u.id %}selected{% endif %}>
                                        {{ u.nomComplet }} ({{ u.email }})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Date de naissance <span class="text-danger">*</span></label>
                            <input type="date" name="dateNaissance" class="form-control" required
                                   value="{{ patient ? patient.dateNaissance|date('Y-m-d') : '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Genre</label>
                            <select name="genre" class="form-select">
                                <option value="">-- Non spécifié --</option>
                                {% set genres = [{'value': 'homme', 'label': 'Homme'}, {'value': 'femme', 'label': 'Femme'}, {'value': 'autre', 'label': 'Autre'}] %}
                                {% for g in genres %}
                                    <option value="{{ g.value }}" {% if patient and patient.genre is not null and patient.genre.value == g.value %}selected{% endif %}>
                                        {{ g.label }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Groupe sanguin</label>
                            <select name="groupeSanguin" class="form-select">
                                <option value="">-- Non spécifié --</option>
                                {% for gs in ['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-'] %}
                                    <option value="{{ gs }}" {% if patient and patient.groupeSanguin == gs %}selected{% endif %}>{{ gs }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Contact urgence</label>
                            <input type="text" name="contactUrgence" class="form-control"
                                   value="{{ patient.contactUrgence ?? '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">N° Sécurité sociale</label>
                            <input type="text" name="numeroSecuriteSociale" class="form-control"
                                   value="{{ patient.numeroSecuriteSociale ?? '' }}">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Allergies</label>
                            <textarea name="allergies" class="form-control" rows="3">{{ patient.allergies ?? '' }}</textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>{{ submit_label }}
                        </button>
                        <a href="{{ path('back_patients') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}