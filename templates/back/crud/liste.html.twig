{% extends 'back/layout.html.twig' %}

{% block title %}{{ entite }} — Back Office{% endblock %}
{% block page_title %}{{ entite }}{% endblock %}

{% block body %}
<div class="card table-card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0"><i class="fas fa-list me-2 text-primary"></i>Liste des {{ entite|lower }}</h5>
        <button class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Ajouter</button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        {% for colonne in colonnes %}
                        <th>{{ colonne }}</th>
                        {% endfor %}
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ligne in lignes %}
                    <tr>
                        {% for champ in champs %}
                        <td>{{ get_cell_value(ligne, champ)|raw }}</td>
                        {% endfor %}
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary" title="Voir"><i class="fas fa-eye"></i></button>
                            <button class="btn btn-sm btn-outline-warning" title="Modifier"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="{{ colonnes|length + 1 }}" class="text-center text-muted py-5">
                            <i class="fas fa-inbox fa-3x mb-3 d-block opacity-25"></i>
                            Aucun élément trouvé
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
