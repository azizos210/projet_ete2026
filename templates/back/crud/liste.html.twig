{% extends 'back/layout.html.twig' %}

{% block title %}{{ entite }} — Back Office{% endblock %}
{% block page_title %}{{ entite }}{% endblock %}

{% if show_route is not defined %}
    {% set show_route = 'back_' ~ entite_slug ~ '_show' %}
{% endif %}
{% if new_route is not defined %}
    {% set new_route = 'back_' ~ entite_slug ~ '_new' %}
{% endif %}
{% if edit_route is not defined %}
    {% set edit_route = 'back_' ~ entite_slug ~ '_edit' %}
{% endif %}
{% if delete_route is not defined %}
    {% set delete_route = 'back_' ~ entite_slug ~ '_delete' %}
{% endif %}
{% set csrf_prefix = delete_route is defined and delete_route ? delete_route|replace({ 'back_': '', '_delete': '' }) : entite_slug %}
{% set actions_available = show_route or edit_route or delete_route %}

{% import _self as table %}

{# ================= SAFE CELL MACRO ================= #}
{% macro cell_value(entity, field) %}
    {% set value = entity %}

    {% for part in field|split('.') %}
        {% if value is not null %}
            {% set value = attribute(value, part) %}
        {% else %}
            {% set value = null %}
        {% endif %}
    {% endfor %}

    {% if value is null %}
        -

    {% elseif value is iterable %}
        {{ value|join(', ') }}

    {% elseif value == true %}
        Oui

    {% elseif value == false %}
        Non

    {% else %}
        {{ value }}
    {% endif %}
{% endmacro %}

{% block body %}

<div class="card table-card">

    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            {{ entite }}
        </h5>

        {% if new_route %}
            <a href="{{ path(new_route) }}" class="btn btn-primary btn-sm">
                Ajouter
            </a>
        {% endif %}
    </div>

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover mb-0">

                <thead class="table-light">
                    <tr>
                        {% for colonne in colonnes %}
                            <th>{{ colonne }}</th>
                        {% endfor %}
                        {% if actions_available %}
                            <th class="text-center">Actions</th>
                        {% endif %}
                    </tr>
                </thead>

                <tbody>

                    {% for ligne in lignes %}
                        <tr>

                            {% for champ in champs %}
                                <td>{{ table.cell_value(ligne, champ) }}</td>
                            {% endfor %}

                            <td class="text-center">

                                {% if show_route %}
                                    <a href="{{ path(show_route, { id: ligne.id }) }}"
                                       class="btn btn-sm btn-outline-primary">
                                        👁
                                    </a>
                                {% endif %}

                                {% if edit_route %}
                                    <a href="{{ path(edit_route, { id: ligne.id }) }}"
                                       class="btn btn-sm btn-outline-warning">
                                        ✏️
                                    </a>
                                {% endif %}

                                {% if delete_route %}
                                    <form method="post"
                                          action="{{ path(delete_route, { id: ligne.id }) }}"
                                          style="display:inline"
                                          onsubmit="return confirm('Supprimer cet élément ?')">

                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token(csrf_prefix ~ '_delete_' ~ ligne.id) }}">

                                        <button class="btn btn-sm btn-outline-danger">
                                            🗑
                                        </button>
                                    </form>
                                {% endif %}

                            </td>
                        </tr>

                    {% else %}
                        <tr>
                            <td colspan="{{ colonnes|length + 1 }}" class="text-center py-5 text-muted">
                                Aucun résultat
                            </td>
                        </tr>
                    {% endfor %}

                </tbody>

            </table>

        </div>

    </div>

</div>

{% endblock %}