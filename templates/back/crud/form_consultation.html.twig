{% extends 'back/layout.html.twig' %}

{% block title %}{{ form_title }} — Back Office{% endblock %}
{% block page_title %}{{ form_title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card table-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="fas fa-{% if consultation %}edit{% else %}plus{% endif %} me-2 text-primary"></i>{{ form_title }}</h5>
                <a href="{{ path('back_consultations') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                </a>
            </div>
            <div class="card-body p-4">
                <form method="post" action="{{ form_action }}">
                    <input type="hidden" name="_token" value="{{ csrf_token(consultation ? 'consultation_edit_' ~ consultation.id : 'consultation_new') }}">

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Dossier médical <span class="text-danger">*</span></label>
                            <select name="dossierMedical" class="form-select" required>
                                <option value="">-- Sélectionner un dossier --</option>
                                {% for d in dossiers_medicaux %}
                                    <option value="{{ d.id }}" {% if selected_dossier == d.id %}selected{% endif %}>
                                        #{{ d.id }} — {{ d.patient.utilisateur.nomComplet ?? 'N/A' }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Médecin <span class="text-danger">*</span></label>
                            <select name="medecin" class="form-select" required>
                                <option value="">-- Sélectionner un médecin --</option>
                                {% for m in medecins %}
                                    <option value="{{ m.id }}" {% if selected_medecin == m.id %}selected{% endif %}>
                                        {{ m.utilisateur.nomComplet ?? 'Dr #' ~ m.id }} ({{ m.specialite }})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Infirmier</label>
                            <select name="infirmier" class="form-select">
                                <option value="">-- Aucun --</option>
                                {% for i in infirmiers %}
                                    <option value="{{ i.id }}" {% if selected_infirmier == i.id %}selected{% endif %}>
                                        {{ i.utilisateur.nomComplet ?? 'Infirmier #' ~ i.id }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Rendez-vous</label>
                            <select name="rendezVous" class="form-select">
                                <option value="">-- Aucun --</option>
                                {% for r in rendez_vous %}
                                    <option value="{{ r.id }}" {% if selected_rdv == r.id %}selected{% endif %}>
                                        {{ r }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Validateur</label>
                            <select name="validateur" class="form-select">
                                <option value="">-- Aucun --</option>
                                {% for v in validateurs %}
                                    <option value="{{ v.id }}" {% if selected_validateur == v.id %}selected{% endif %}>
                                        {{ v.utilisateur.nomComplet ?? 'Validateur #' ~ v.id }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Statut <span class="text-danger">*</span></label>
                            <select name="statut" class="form-select" required>
                                {% for s in statuts %}
                                    <option value="{{ s.value }}" {% if selected_statut == s.value %}selected{% endif %}>
                                        {{ s.value|replace({'_': ' '})|capitalize }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Date et heure <span class="text-danger">*</span></label>
                            <input type="datetime-local" name="date" class="form-control" required
                                   value="{{ consultation ? consultation.date|date('Y-m-d\\TH:i') : '' }}">
                        </div>
                    </div>

                    <hr class="my-4">
                    <h6 class="fw-semibold mb-3"><i class="fas fa-notes-medical me-2 text-primary"></i>Détails médicaux</h6>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Symptômes</label>
                            <textarea name="symptomes" class="form-control" rows="4">{{ consultation.symptomes ?? '' }}</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Examen clinique</label>
                            <textarea name="examenClinique" class="form-control" rows="4">{{ consultation.examenClinique ?? '' }}</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Diagnostic</label>
                            <textarea name="diagnostic" class="form-control" rows="4">{{ consultation.diagnostic ?? '' }}</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Recommandations</label>
                            <textarea name="recommandations" class="form-control" rows="4">{{ consultation.recommandations ?? '' }}</textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>{{ submit_label }}
                        </button>
                        <a href="{{ path('back_consultations') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}