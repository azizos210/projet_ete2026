{% extends 'back/layout.html.twig' %}

{% block title %}{{ form_title }} — Back Office{% endblock %}
{% block page_title %}{{ form_title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card table-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="fas fa-{% if secretaire %}edit{% else %}plus{% endif %} me-2 text-primary"></i>{{ form_title }}</h5>
                <a href="{{ path('back_secretaires') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i>Retour à la liste
                </a>
            </div>
            <div class="card-body p-4">
                <form method="post" action="{{ form_action }}">
                    <input type="hidden" name="_token" value="{{ csrf_token(secretaire ? 'secretaire_edit_' ~ secretaire.id : 'secretaire_new') }}">

                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Utilisateur <span class="text-danger">*</span></label>
                            <select name="utilisateur" class="form-select" required>
                                <option value="">-- Sélectionner un utilisateur --</option>
                                {% for u in utilisateurs %}
                                    <option value="{{ u.id }}" {% if selected_utilisateur == u.id %}selected{% endif %}>
                                        {{ u.nomComplet }} ({{ u.email }})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Poste d'accueil</label>
                            <input type="text" name="posteAccueil" class="form-control"
                                   value="{{ secretaire.posteAccueil ?? '' }}">
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>{{ submit_label }}
                        </button>
                        <a href="{{ path('back_secretaires') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}