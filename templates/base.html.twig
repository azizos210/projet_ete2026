<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Hôpital — Plateforme de Gestion{% endblock %}</title>

    {# Bootstrap 5 #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>
<body class="d-flex flex-column min-vh-100">

{# ===== NAVBAR ===== #}
<nav class="navbar navbar-expand-lg navbar-dark" style="background: linear-gradient(135deg, #006D77, #004D56);">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">
            <i class="fas fa-hospital me-2"></i>Hôpital
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/front">
                        <i class="fas fa-desktop me-1"></i>Frontend Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/back">
                        <i class="fas fa-cogs me-1"></i>Backend Admin
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('admin_dashboard') }}">
                                <i class="fas fa-cog me-1"></i>Admin
                            </a>
                        </li>
                    {% endif %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i>{{ app.user.fullName }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    <i class="fas fa-sign-out-alt me-1"></i>Déconnexion
                                </a>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-light ms-2" href="{{ path('app_register') }}">Inscription</a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

{# ===== FLASH MESSAGES ===== #}
<div class="container mt-3">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

{# ===== CONTENU ===== #}
<main class="container my-4 flex-grow-1">
    {% block body %}{% endblock %}
</main>

{# ===== FOOTER ===== #}
<footer class="bg-dark text-light py-3 mt-auto">
    <div class="container text-center">
        <div class="row">
            <div class="col">
                <small>&copy; {{ "now"|date("Y") }} Hôpital — Plateforme de Gestion Hospitalière</small>
            </div>
            <div class="col">
                <a href="/front" class="text-light me-3"><i class="fas fa-desktop"></i> Frontend</a>
                <a href="/back" class="text-light"><i class="fas fa-cogs"></i> Backend</a>
            </div>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
